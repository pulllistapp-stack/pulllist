# Database
# SQLite (default for dev — zero setup)
DATABASE_URL=sqlite+aiosqlite:///./pulllist.db

# Postgres (when you outgrow SQLite — uncomment + comment SQLite above)
# DATABASE_URL=postgresql+asyncpg://pulllist:pulllist@localhost:5432/pulllist

# Redis (optional — for caching + background jobs later)
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Pokemon TCG API (no key needed for low volume, but recommended)
# Get free key at https://dev.pokemontcg.io
POKEMONTCG_API_KEY=

# Environment
ENV=development
DEBUG=true
